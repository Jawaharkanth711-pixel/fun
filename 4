from PIL import Image
import os
os.makedirs("album",exist_ok=True)

for f in os.listdir():
    if f.endswith(".jpg"):
        img=Image.open(f)
        img.thumbnail((800,600))
        img.save("album/"+f)

print("Images resized successfully") #4a

